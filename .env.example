# ===========================================
# PicArt 图片社区后端 API 环境配置
# ===========================================

# 应用配置
PORT=3000
NODE_ENV=development

# ===========================================
# 数据库配置 (MySQL)
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=picart
DB_SYNC=false
DB_LOGGING=true

# ===========================================
# JWT 配置
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=180d
JWT_AUTH_USER_CACHE_TTL_MS=60000

# ===========================================
# Redis 缓存配置
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-pasword
CACHE_TTL=5000
CACHE_MAX=100
MEMORY_CACHE_TTL=60000
MEMORY_CACHE_SIZE=5000

# ===========================================
# 邮件配置 (邮件通知功能)
# ===========================================
MAIL_FROM_NAME=PicArt
MAIL_FROM=noreply@example.com
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ===========================================
# 上传配置 s3 local
# ===========================================
MULTER_STORAGE=local
MULTER_DEST=uploads
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_MAX_FILE_COUNT=10
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,application/zip,application/x-zip-compressed,application/vnd.rar,application/x-rar-compressed,application/x-7z-compressed,video/mp4,audio/mpeg
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_ENDPOINT=http://localhost:3000
AWS_BUCKET=your-bucket-name
AWS_CDN_DOMAIN=http://localhost:3000
# 选项开启后将域名模式改为url;如https://example.com/bucketname
AWS_FORCE_PATH_STYLE=true

# ===========================================
# Elasticsearch 配置（可选）
# 如果不配置，搜索功能将回退到数据库 LIKE 查询
# ===========================================
# ES 节点地址，例如：http://localhost:9200
# 留空则不启用 Elasticsearch
ELASTICSEARCH_NODE=
# ES 认证用户名（如果需要）
ELASTICSEARCH_USERNAME=
# ES 认证密码（如果需要）
ELASTICSEARCH_PASSWORD=
# 是否使用 IK 分词器（需要安装 IK 插件）
# 默认 false，使用 standard 分词器
# 设为 true 并安装 IK 插件可获得更好的中文分词效果
ELASTICSEARCH_USE_IK=false

# ===========================================
# 图片压缩配置 (已启用最优配置)
# ===========================================
# 是否启用图片压缩 - 默认启用
UPLOAD_COMPRESSION_ENABLED=true

# 压缩输出格式: webp (最优) | jpeg | png | avif
UPLOAD_COMPRESSION_FORMAT=webp

# 压缩质量 1-100 - 85 是质量和体积的最佳平衡点
UPLOAD_COMPRESSION_QUALITY=85

# 最大分辨率限制（4K，覆盖 99.9% 设备）
UPLOAD_COMPRESSION_MAX_WIDTH=3840
UPLOAD_COMPRESSION_MAX_HEIGHT=2160

# 保留原图 - 用于下载和高质量查看场景
UPLOAD_KEEP_ORIGINAL=true

# ===========================================
# 前端预压缩建议配置（后端提供给前端的建议值）
# ===========================================
# 建议前端预压缩的最大宽度（通过 API /upload/config 获取）
UPLOAD_CLIENT_MAX_WIDTH=1920
# 建议前端预压缩质量（后端会重新处理，前端可稍低）
UPLOAD_CLIENT_QUALITY=75
# 建议前端输出格式
UPLOAD_CLIENT_FORMAT=webp
