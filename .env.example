# =============================================================================
# PicArt 图片社区后端 API - 环境配置文件
# =============================================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际环境修改配置值
# 3. 生产环境请使用强密码和密钥
# =============================================================================


# =============================================================================
# 基础应用配置
# =============================================================================

# 服务端口
PORT=3000

# 运行环境: development | production | test
NODE_ENV=development


# =============================================================================
# 数据库配置 (MySQL 8.0+)
# =============================================================================

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=picart

# 是否自动同步数据库结构（生产环境建议设为 false）
DB_SYNC=false

# 是否启用 SQL 日志
DB_LOGGING=true


# =============================================================================
# Redis 缓存配置
# =============================================================================

# Redis 连接地址
REDIS_URL=redis://localhost:6379

# Redis 密码（无密码则留空）
REDIS_PASSWORD=your-redis-password

# 缓存默认 TTL（毫秒）
CACHE_TTL=5000

# 最大缓存条目数
CACHE_MAX=100

# 内存缓存配置
MEMORY_CACHE_TTL=60000
MEMORY_CACHE_SIZE=5000


# =============================================================================
# JWT 认证配置
# =============================================================================

# 访问令牌密钥（生产环境请使用强密钥）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 访问令牌有效期
JWT_EXPIRES_IN=7d

# 刷新令牌密钥
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# 刷新令牌有效期
JWT_REFRESH_EXPIRES_IN=180d

# 认证用户信息缓存时间（毫秒）
JWT_AUTH_USER_CACHE_TTL_MS=60000


# =============================================================================
# 邮件服务配置
# =============================================================================

MAIL_FROM_NAME=PicArt
MAIL_FROM=noreply@example.com
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password


# =============================================================================
# 文件上传配置
# =============================================================================

# -----------------------------------------------------------------------------
# 上传基础配置
# -----------------------------------------------------------------------------

# 存储类型: local (本地) | s3 (对象存储)
MULTER_STORAGE=local

# 本地存储路径（仅 local 模式有效）
MULTER_DEST=uploads

# 单次上传最大文件数量
UPLOAD_MAX_FILE_COUNT=10

# 允许的 MIME 类型（逗号分隔）
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,image/heic,image/heif,image/tiff,image/avif,video/mp4,video/webm,video/quicktime,video/x-msvideo,video/mpeg,video/avi,audio/mpeg,audio/wav,audio/ogg,audio/aac,application/pdf,application/zip,application/x-zip-compressed,application/vnd.rar,application/x-rar-compressed,application/x-7z-compressed

# -----------------------------------------------------------------------------
# 文件大小限制（单位：MB）
# -----------------------------------------------------------------------------

# 图片限制：默认 20MB
UPLOAD_MAX_IMAGE_SIZE=20

# 视频限制：默认 500MB
UPLOAD_MAX_VIDEO_SIZE=500

# 音频限制：默认 50MB
UPLOAD_MAX_AUDIO_SIZE=50

# 其他文件限制：默认 100MB
UPLOAD_MAX_OTHER_SIZE=100

# 【向后兼容】全局文件大小限制（如果未配置上述类型限制则使用此值，单位：MB）
# UPLOAD_MAX_FILE_SIZE=10

# -----------------------------------------------------------------------------
# S3 对象存储配置（MULTER_STORAGE=s3 时必填）
# -----------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_BUCKET=your-bucket-name
AWS_ENDPOINT=http://localhost:3000
AWS_CDN_DOMAIN=http://localhost:3000

# 是否使用路径样式 URL（如: https://example.com/bucketname）
AWS_FORCE_PATH_STYLE=true


# =============================================================================
# 图片处理配置
# =============================================================================

# 是否启用图片压缩
UPLOAD_COMPRESSION_ENABLED=true

# 压缩输出格式: webp | jpeg | png | avif
UPLOAD_COMPRESSION_FORMAT=webp

# 压缩质量（1-100，85 是质量和体积的最佳平衡点）
UPLOAD_COMPRESSION_QUALITY=85

# 最大分辨率限制（超过则缩放）
UPLOAD_COMPRESSION_MAX_WIDTH=3840
UPLOAD_COMPRESSION_MAX_HEIGHT=2160

# 是否保留原图
UPLOAD_KEEP_ORIGINAL=true


# =============================================================================
# 视频处理配置
# =============================================================================

# 是否启用视频压缩
VIDEO_COMPRESSION_ENABLED=true

# 编码质量（0-51，越小质量越好，默认 23）
VIDEO_COMPRESSION_CRF=23

# 编码速度预设（ultrafast, superfast, veryfast, faster, fast, medium, slow, slower, veryslow）
VIDEO_COMPRESSION_PRESET=medium

# 最大分辨率限制
VIDEO_COMPRESSION_MAX_WIDTH=1920
VIDEO_COMPRESSION_MAX_HEIGHT=1080

# 视频码率限制
VIDEO_COMPRESSION_BITRATE=5000k

# 音频码率
VIDEO_COMPRESSION_AUDIO_BITRATE=128k

# 最小压缩文件大小（小于此值的文件不压缩，单位：MB，默认 10MB）
VIDEO_COMPRESSION_MIN_SIZE=10


# =============================================================================
# 前端预压缩建议配置
# =============================================================================
# 这些配置通过 API 提供给前端，建议前端在上传前进行预压缩

# 建议前端预压缩的最大宽度
UPLOAD_CLIENT_MAX_WIDTH=1920

# 建议前端预压缩质量（后端会重新处理，前端可稍低）
UPLOAD_CLIENT_QUALITY=75

# 建议前端输出格式
UPLOAD_CLIENT_FORMAT=webp


# =============================================================================
# 静态资源缓存配置
# =============================================================================

# 缓存时间（单位：秒，默认 30 天）
STATIC_IMAGE_CACHE_MAX_AGE_SECONDS=2592000

# 是否附加 immutable 指令
STATIC_IMAGE_CACHE_IMMUTABLE=true


# =============================================================================
# Elasticsearch 搜索配置（可选）
# =============================================================================
# 如果不配置，搜索功能将回退到数据库 LIKE 查询

# ES 节点地址，例如：http://localhost:9200（留空则不启用）
ELASTICSEARCH_NODE=

# ES 认证用户名（如果需要）
ELASTICSEARCH_USERNAME=

# ES 认证密码（如果需要）
ELASTICSEARCH_PASSWORD=

# 是否使用 IK 分词器（需要安装 IK 插件，默认 false）
ELASTICSEARCH_USE_IK=false
